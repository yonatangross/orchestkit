{
  "description": "OrchestKit hooks - 39 global + 44 agent-scoped + 20 skill-scoped = 103 total hooks (4 native HTTP, 5 type:prompt, 13 once:true context loaders). All timeouts in SECONDS per CC spec.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs pretool/bash/sync-bash-dispatcher",
            "timeout": 15,
            "statusMessage": "Validating command..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs pretool/write-edit/sync-write-edit-dispatcher",
            "timeout": 15,
            "statusMessage": "Checking file safety..."
          }
        ]
      },
      {
        "matcher": "mcp__context7__*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs pretool/mcp/context7-tracker",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__memory__*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs pretool/mcp/memory-validator",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs pretool/task/sync-task-dispatcher",
            "timeout": 15,
            "statusMessage": "Preparing agent..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs pretool/read/tldr-summary",
            "timeout": 15,
            "statusMessage": "Analyzing file structure..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|Agent|TaskUpdate|TaskCreate|Skill|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs posttool/unified-dispatcher",
            "async": true,
            "timeout": 60
          },
          {
            "type": "prompt",
            "prompt": "Analyze this tool output for solution indicators. Tool: $TOOL_INPUT. Did this tool use resolve a previously reported problem? Look for: tests now passing, errors gone, feature working, explicit fix confirmation. If a solution is detected, return {continue:true, hookSpecificOutput:{additionalContext:'[Solution Detected] The previous issue appears resolved. Consider confirming with the user.'}}. If no solution detected, return {continue:true, suppressOutput:true}.",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Write|Edit|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs posttool/failure-handler",
            "timeout": 10,
            "statusMessage": "Analyzing failure..."
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs permission/unified-dispatcher",
            "timeout": 10,
            "statusMessage": "Evaluating permissions..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs permission/auto-approve-project-writes",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs prompt/unified-dispatcher",
            "timeout": 15,
            "statusMessage": "Processing prompt..."
          },
          {
            "type": "prompt",
            "prompt": "Check if this user prompt mentions any known antipatterns. Known antipatterns: offset pagination (use cursor-based instead), manual JWT validation (use established libraries), storing passwords in plaintext (use bcrypt/argon2), global mutable state (use dependency injection), synchronous file I/O (use async), N+1 queries (use eager loading), polling for real-time (use SSE/WebSocket). User prompt: '$USER_PROMPT'. If an antipattern is detected, return a hookSpecificOutput with additionalContext containing a brief warning about the better alternative. If no antipattern detected, return continue:true with suppressOutput:true.",
            "timeout": 15
          },
          {
            "type": "prompt",
            "prompt": "Classify this user message's communication style. Message: '$USER_PROMPT'. Determine: (1) verbosity: terse (under 30 chars, no explanation), moderate (30-150 chars), or detailed (150+ chars, multiple sentences, includes rationale). (2) type: question (asking how/what/why), command (imperative verb like fix/add/create), or discussion (exploring ideas, trade-offs). (3) level: beginner (asking basics, step-by-step), intermediate (standard dev terms like API/component/migration), or expert (advanced concepts like CQRS/sharding/monads). Return {continue:true, suppressOutput:true}. This classification is for analytics only.",
            "timeout": 10
          },
          {
            "type": "prompt",
            "prompt": "Extract user intents from this message: '$USER_PROMPT'. Classify each intent as: decision (user chose X, going with Y), preference (user prefers/likes/always uses X), problem (error/bug/broken/not working), question (how/what/why), or instruction (do X, fix Y). For decisions, note alternatives if mentioned (X over Y). For all intents, extract technology/tool entities mentioned and any rationale (because/since clauses). Return {continue:true, hookSpecificOutput:{additionalContext:'[Intent: <type>] <brief summary>'}} for significant intents, or {continue:true, suppressOutput:true} if the message is a simple instruction with no notable intent.",
            "timeout": 15
          },
          {
            "type": "prompt",
            "prompt": "Analyze this user message for satisfaction signals. Message: '$USER_PROMPT'. Is the user expressing: (a) satisfaction/approval (e.g., 'great', 'perfect', 'that works'), (b) frustration/dissatisfaction (e.g., 'still broken', 'wrong again', sarcasm like 'great, now its even worse'), or (c) neutral/instruction. Consider tone and sarcasm. If satisfied, return {continue:true, suppressOutput:true}. If frustrated, return {continue:true, hookSpecificOutput:{additionalContext:'[User Satisfaction: frustrated] — Consider acknowledging the issue and adjusting approach.'}}. If neutral, return {continue:true, suppressOutput:true}.",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs lifecycle/unified-dispatcher",
            "async": true,
            "timeout": 60
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs lifecycle/sync-session-dispatcher",
            "timeout": 20,
            "statusMessage": "Loading session context..."
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs lifecycle/session-handoff-injector",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs lifecycle/sync-session-end-dispatcher",
            "timeout": 30,
            "statusMessage": "Saving session data..."
          },
          {
            "type": "http",
            "url": "https://hq.yonatangross.com/api/hooks/cc-event",
            "headers": {
              "Authorization": "Bearer $ORCHESTKIT_HOOK_TOKEN"
            },
            "allowedEnvVars": ["ORCHESTKIT_HOOK_TOKEN"],
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs lifecycle/session-handoff-generator",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs stop/unified-dispatcher",
            "async": true,
            "timeout": 60
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/stop-uncommitted-check.mjs",
            "timeout": 10,
            "statusMessage": "Checking uncommitted changes..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs subagent-start/unified-dispatcher",
            "timeout": 10,
            "statusMessage": "Configuring agent..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs subagent-stop/unified-dispatcher",
            "async": true,
            "timeout": 60
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs subagent-stop/sync-subagent-stop-dispatcher",
            "timeout": 15,
            "statusMessage": "Processing agent results..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs notification/unified-dispatcher",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs lifecycle/pre-compact-saver",
            "timeout": 10,
            "statusMessage": "Saving context before compact..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs teammate-idle/unified-dispatcher",
            "timeout": 15,
            "async": true,
            "statusMessage": "Checking teammate status..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs task-completed/completion-tracker",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs worktree/worktree-lifecycle-logger",
            "timeout": 10
          },
          {
            "type": "http",
            "url": "https://hq.yonatangross.com/api/hooks/cc-event",
            "headers": {
              "Authorization": "Bearer $ORCHESTKIT_HOOK_TOKEN"
            },
            "allowedEnvVars": ["ORCHESTKIT_HOOK_TOKEN"],
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs worktree/worktree-lifecycle-logger",
            "timeout": 10
          },
          {
            "type": "http",
            "url": "https://hq.yonatangross.com/api/hooks/cc-event",
            "headers": {
              "Authorization": "Bearer $ORCHESTKIT_HOOK_TOKEN"
            },
            "allowedEnvVars": ["ORCHESTKIT_HOOK_TOKEN"],
            "timeout": 10
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://hq.yonatangross.com/api/hooks/cc-event",
            "headers": {
              "Authorization": "Bearer $ORCHESTKIT_HOOK_TOKEN"
            },
            "allowedEnvVars": ["ORCHESTKIT_HOOK_TOKEN"],
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs instructions-loaded/instructions-loaded-dispatcher",
            "timeout": 15,
            "statusMessage": "Indexing loaded rules..."
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs config-change/settings-reload",
            "timeout": 10,
            "statusMessage": "Checking settings change..."
          }
        ]
      }
    ],
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs setup/sync-setup-dispatcher",
            "timeout": 120,
            "statusMessage": "Running first-time setup..."
          }
        ]
      }
    ]
  }
}
