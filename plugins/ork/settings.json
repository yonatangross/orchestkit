{
  "$schema": "https://claude.ai/schemas/plugin-settings.json",
  "respectGitignore": true,
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5",
    "ORCHESTKIT_PROTECTED_BRANCHES": "main,master",
    "ORCHESTKIT_COMMIT_SCOPE": "optional",
    "ORCHESTKIT_PERF_SNAPSHOT_ENABLED": "1",
    "ORCHESTKIT_LOG_LEVEL": "warn",
    "ORCHESTKIT_AGENT_BROWSER_ALLOW_LOCALHOST": "1"
  },
  "plansDirectory": ".claude/plans",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "mcp__context7__*",
      "mcp__memory__*",
      "mcp__ork-elicit__ork_elicit"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git push -f origin main)",
      "Bash(git push -f origin master)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(> /dev/sd*)",
      "Bash(:(){ :|:& };:)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bin/statusline-context-writer.sh"
  },
  "keybindings": [
    { "key": "ctrl+k ctrl+f", "skill": "fix-issue" },
    { "key": "ctrl+k ctrl+i", "skill": "implement" },
    { "key": "ctrl+k ctrl+e", "skill": "explore" },
    { "key": "ctrl+k ctrl+r", "skill": "review-pr" },
    { "key": "ctrl+k ctrl+m", "skill": "memory" },
    { "key": "ctrl+k ctrl+a", "skill": "assess" },
    { "key": "ctrl+k ctrl+c", "skill": "commit" },
    { "key": "ctrl+k ctrl+h", "skill": "help" }
  ],
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Orchestrating",
      "Coordinating",
      "Synthesizing",
      "Architecting",
      "Dispatching",
      "Producing",
      "Rendering",
      "Composing"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["${projectDir}", "/tmp", "~/.claude"],
      "denyRead": ["~/.aws/credentials", "~/.ssh/*", "~/.gnupg/*"]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.npmjs.org",
        "*.pypi.org",
        "registry.terraform.io",
        "api.anthropic.com"
      ]
    }
  },
  "fileSuggestion": {
    "type": "command",
    "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bin/file-suggestion.sh"
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "/ork:memory search to find past decisions",
      "ctrl+k ctrl+f to quick-fix an issue",
      "/ork:analytics shows usage patterns",
      "/ork:explore for deep codebase understanding",
      "/ork:verify after implementation to validate",
      "/ork:assess rates code quality 0-10",
      "/ork:doctor checks plugin health",
      "/ork:brainstorm for design exploration",
      "Use /ork:commit for conventional commits",
      "/ork:help lists all available skills"
    ]
  }
}
