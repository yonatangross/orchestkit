{
  "$schema": "context://identity/v1",
  "_meta": {
    "position": "START",
    "token_budget": 200,
    "auto_load": "always",
    "compress": "never",
    "description": "Project identity and immutable constraints - ALWAYS loaded at START of context"
  },

  "project": {
    "name": "OrchestKit",
    "display_name": "OrchestKit Complete",
    "type": "Claude Code Plugin Ecosystem",
    "version": "7.3.0",
    "repository": "https://github.com/yonatangross/orchestkit"
  },

  "constraints": [
    "NEVER commit directly to main/dev branches",
    "ALWAYS run tests before committing code",
    "NEVER store secrets in code (use .env files, excluded from git)",
    "ALWAYS check SKILL.md for skill patterns and usage",
    "Edit src/, NEVER edit plugins/ directly",
    "Run npm run build after editing src/"
  ],

  "tech_stack": {
    "plugin": {
      "skills": "89 SKILL.md files (YAML frontmatter + Markdown)",
      "agents": "31 agent definitions (CC 2.1.72 format)",
      "hooks": "99 TypeScript hooks (compiled to ESM)"
    },
    "hooks": {
      "language": "TypeScript 5.x",
      "runtime": "Node.js (ESM)",
      "testing": "Vitest",
      "build": "tsup"
    },
    "docs_site": {
      "framework": "Next.js",
      "language": "TypeScript",
      "hosting": "Vercel"
    }
  },

  "team": {
    "maintainer": "Yonatan"
  },

  "claude_code_version": ">= 2.1.72"
}
