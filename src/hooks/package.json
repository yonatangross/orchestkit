{
  "name": "@orchestkit/hooks",
  "version": "1.0.0",
  "type": "module",
  "description": "TypeScript/ESM hooks for OrchestKit Claude Plugin",
  "main": "./dist/hooks.mjs",
  "types": "./dist/types.d.ts",
  "bin": {
    "run-hook": "./bin/run-hook.mjs"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run --config vitest.property.config.ts",
    "bench": "vitest bench --run --config vitest.bench.config.ts",
    "lint:biome": "biome check src/",
    "lint:biome:fix": "biome check --write src/",
    "clean": "rm -rf dist coverage",
    "validate": "node scripts/validate-registry.mjs",
    "prebuild": "node scripts/preflight-deps.mjs",
    "pretest": "node scripts/preflight-deps.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.0",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "claude-code",
    "hooks",
    "typescript",
    "esm",
    "orchestkit"
  ],
  "license": "MIT"
}
