{
  "name": "@orchestkit/hook-contract",
  "version": "0.1.1",
  "description": "Hook event contract for OrchestKit — types, JSON schemas, and a thin validation helper. Zero runtime deps.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./events": {
      "types": "./dist/esm/events.d.ts",
      "import": "./dist/esm/events.js",
      "require": "./dist/cjs/events.js"
    },
    "./schemas": {
      "types": "./dist/esm/schemas.d.ts",
      "import": "./dist/esm/schemas.js",
      "require": "./dist/cjs/schemas.js"
    },
    "./validate": {
      "types": "./dist/esm/validate.d.ts",
      "import": "./dist/esm/validate.js",
      "require": "./dist/cjs/validate.js"
    },
    "./signing": {
      "types": "./dist/esm/signing.d.ts",
      "import": "./dist/esm/signing.js",
      "require": "./dist/cjs/signing.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prebuild": "npm run codegen:check",
    "build": "npm run build:esm && npm run build:cjs && node scripts/rename-cjs.mjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen.mjs --check",
    "publish:dry-run": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "js-yaml": "^5.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "claude-code",
    "orchestkit",
    "hooks",
    "contract",
    "schema",
    "types"
  ],
  "author": "Yonatan Gross",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yonatangross/orchestkit.git",
    "directory": "packages/hook-contract"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
